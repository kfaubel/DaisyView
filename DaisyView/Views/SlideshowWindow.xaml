<Window x:Class="DaisyView.Views.SlideshowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DaisyView - Slideshow"
        Background="Black"
        AllowsTransparency="False"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="Manual">
    
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!-- Image Display -->
        <Image x:Name="ImageDisplay" 
               Grid.Row="0"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Visibility="Visible" />

        <!-- Video Display -->
        <MediaElement x:Name="VideoDisplay"
                      Grid.Row="0"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      ScrubbingEnabled="True"
                      MediaOpened="VideoDisplay_MediaOpened" />

        <!-- Video Conversion/Not Supported Overlay -->
        <StackPanel x:Name="VideoNotSupportedOverlay"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock x:Name="OverlayIconText" 
                       Text="⏳"
                       FontSize="48"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />
            <TextBlock x:Name="OverlayTitleText" 
                       Text="Converting video..."
                       FontSize="18"
                       Foreground="White"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="OverlaySubtitleText" 
                       Text="Please wait, converting WebM to MP4"
                       FontSize="12"
                       Foreground="#AAAAAA"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0" />
        </StackPanel>

        <!-- File Name Display at Bottom -->
        <StackPanel Grid.Row="1" 
                    Background="Black"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="10,0">
            <TextBlock x:Name="FileNameDisplay" 
                       Foreground="White"
                       FontSize="14"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>

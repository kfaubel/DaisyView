<Window x:Class="DaisyView.Views.MoveToDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move Files To..." 
        Height="500" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Folder Tree View -->
        <TreeView Grid.Row="0" 
                  Name="FolderTreeView"
                  Background="{StaticResource PanelBrush}"
                  Foreground="{StaticResource ForegroundBrush}"
                  Margin="10"
                  SelectedItemChanged="TreeViewItem_SelectedItemChanged" />

        <!-- Buttons for Move To Dialog -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="NewFolderButton" 
                    Content="New Folder" 
                    Width="100"
                    Margin="5"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="NewFolderButton_Click" />
            <Button Name="MoveButton" 
                    Content="Move" 
                    Width="100"
                    Margin="5"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="MoveButton_Click"
                    IsEnabled="False" />
            <Button Name="CancelButton" 
                    Content="Cancel" 
                    Width="100"
                    Margin="5"
                    Background="{StaticResource BorderBrush}"
                    Foreground="{StaticResource ForegroundBrush}"
                    Click="CancelButton_Click" />
        </StackPanel>

        <!-- Or Trash Option -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,0,10,10">
            <Button Name="TrashButton" 
                    Content="Move to Trash" 
                    Width="150"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    Click="TrashButton_Click" />
        </StackPanel>
    </Grid>
</Window>

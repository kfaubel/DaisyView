<Window x:Class="DaisyView.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DaisyView.Views"
        Title="DaisyView - Image Viewer" 
        Height="800" 
        Width="1200"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <local:BoolToRedBrushConverter x:Key="BoolToRedBrushConverter" />
        <local:ByteArrayToBitmapImageConverter x:Key="ByteArrayToBitmapImageConverter" />
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter" />
        
        <!-- Size Button Style with box border -->
        <Style x:Key="SizeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Icon Button Style - removes default border and focus visuals -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Disabled-Aware Icon Button Style - ensures child TextBlocks also change color when disabled -->
        <Style x:Key="DisabledAwareIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#666666" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Icon ToggleButton Style - removes default border and focus visuals -->
        <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Expander Button Style -->
        <Style x:Key="ExpanderButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16" SnapsToDevicePixels="True">
                            <TextBlock Text="▶" Foreground="{StaticResource ForegroundBrush}" 
                                      Margin="2,0,0,2" FontSize="10"
                                      Name="Arrow"
                                      RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: File System Tree View and Favorites -->
        <Grid Grid.Column="0" Background="{StaticResource PanelBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="150" />
            </Grid.RowDefinitions>

            <!-- Tree View -->
            <TreeView Grid.Row="0" 
                      ItemsSource="{Binding RootNodes}"
                      Background="{StaticResource PanelBrush}"
                      Foreground="{StaticResource ForegroundBrush}"
                      Name="FolderTreeView"
                      SelectedItemChanged="TreeViewItem_SelectedItemChanged">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsActive, Mode=TwoWay}" />
                        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                        <Setter Property="Padding" Value="2" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="OverridesDefaultStyle" Value="True" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Expander -->
                                        <ToggleButton Grid.Column="0" Grid.Row="0" 
                                                    Name="Expander"
                                                    ClickMode="Press"
                                                    IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                    Style="{StaticResource ExpanderButtonStyle}" />
                                        
                                        <!-- Header -->
                                        <Border Grid.Column="1" Grid.Row="0"
                                               Name="Bd"
                                               Background="{TemplateBinding Background}"
                                               Padding="{TemplateBinding Padding}"
                                               SnapsToDevicePixels="True">
                                            <ContentPresenter x:Name="PART_Header"
                                                            ContentSource="Header"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center" />
                                        </Border>
                                        
                                        <!-- Items -->
                                        <ItemsPresenter Grid.Column="1" Grid.Row="1" x:Name="ItemsHost" />
                                    </Grid>
                                    
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Bd" Property="Background" Value="Transparent" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Resources>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Favorites Label -->
            <TextBlock Grid.Row="1" 
                       Text="Favorites" 
                       Padding="10,5"
                       FontWeight="Bold"
                       Foreground="{StaticResource ForegroundBrush}" />

            <!-- Favorites List -->
            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding Favorites}"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     SelectionChanged="FavoriteFolder_SelectionChanged" />
        </Grid>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" 
                      HorizontalAlignment="Stretch" 
                      Background="{StaticResource BorderBrush}" />

        <!-- RIGHT PANEL: Thumbnails and Controls -->
        <Grid Grid.Column="2" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- TOP TOOLBAR -->
            <DockPanel Grid.Row="0" 
                       Background="{StaticResource PanelBrush}"
                       Margin="10">
                
                <!-- Slideshow Button - Right side -->
                <Button DockPanel.Dock="Right"
                        Width="40"
                        Height="40"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="Start slideshow"
                        Command="{Binding OpenSlideshowCommand}">
                    <TextBlock Text="⛶" FontSize="24" Foreground="White" />
                </Button>

                <!-- Left side controls -->
                <StackPanel Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            Height="50">
                
                <!-- Thumbnail Size Selection - Icon Buttons with Box -->
                <Border BorderThickness="1" 
                        BorderBrush="White"
                        CornerRadius="4"
                        Padding="2"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <!-- Small Size Button -->
                        <Button Name="SmallSizeButton" 
                                Width="36"
                                Height="36"
                                Foreground="White"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Small thumbnails"
                                Click="SmallSizeButton_Click"
                                Tag="Small">
                            <TextBlock Text="■" FontSize="10" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground, Mode=OneWay}" />
                        </Button>
                        
                        <!-- Medium Size Button -->
                        <Button Name="MediumSizeButton" 
                                Width="36"
                                Height="36"
                                Foreground="White"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Medium thumbnails"
                                Click="MediumSizeButton_Click"
                                Tag="Medium">
                            <TextBlock Text="■" FontSize="18" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground, Mode=OneWay}" />
                        </Button>
                        
                        <!-- Large Size Button -->
                        <Button Name="LargeSizeButton" 
                                Width="36"
                                Height="36"
                                Foreground="White"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Large thumbnails"
                                Click="LargeSizeButton_Click"
                                Tag="Large">
                            <TextBlock Text="■" FontSize="24" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground, Mode=OneWay}" />
                        </Button>
                    </StackPanel>
                </Border>
                <Button Name="CopyButton" 
                        Width="40"
                        Height="40"
                        Margin="0,0,5,0"
                        Foreground="White"
                        Style="{StaticResource DisabledAwareIconButtonStyle}"
                        ToolTip="Copy marked images"
                        IsEnabled="{Binding MoveButtonEnabled}"
                        Click="CopyButton_Click">
                    <TextBlock Text="📑" FontSize="20" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=IsEnabled, Converter={StaticResource BoolToBrushConverter}}" />
                </Button>

                <!-- Cut Button -->
                <Button Name="CutButton" 
                        Width="40"
                        Height="40"
                        Margin="0,0,5,0"
                        Foreground="White"
                        Style="{StaticResource DisabledAwareIconButtonStyle}"
                        ToolTip="Cut marked images"
                        IsEnabled="{Binding MoveButtonEnabled}"
                        Click="CutButton_Click">
                    <TextBlock Text="✂" FontSize="20" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=IsEnabled, Converter={StaticResource BoolToBrushConverter}}" />
                </Button>

                <!-- Paste Button -->
                <Button Name="PasteButton" 
                        Width="40"
                        Height="40"
                        Margin="0,0,5,0"
                        Foreground="White"
                        Style="{StaticResource DisabledAwareIconButtonStyle}"
                        ToolTip="Paste images"
                        IsEnabled="{Binding HasClipboardContent}"
                        Click="PasteButton_Click">
                    <TextBlock Text="📋" FontSize="20" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}" />
                </Button>

                <!-- Delete Button - Trashcan Icon -->
                <Button Name="DeleteButton" 
                        Width="40"
                        Height="40"
                        Margin="0,0,10,0"
                        Foreground="White"
                        Style="{StaticResource DisabledAwareIconButtonStyle}"
                        ToolTip="Delete marked images (to recycle bin)"
                        IsEnabled="{Binding MoveButtonEnabled}"
                        Click="DeleteButton_Click">
                    <TextBlock Text="🗑" FontSize="20" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=IsEnabled, Converter={StaticResource BoolToBrushConverter}}" />
                </Button>

                <!-- Random Toggle - Shuffle Icon -->
                <ToggleButton Name="RandomButton" 
                              Width="40"
                              Height="40"
                              Margin="0,0,10,0"
                              ToolTip="Toggle random display"
                              IsChecked="{Binding RandomEnabled, Mode=TwoWay}"
                              Command="{Binding ToggleRandomCommand}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource IconToggleButtonStyle}">
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="Gold" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                    <TextBlock Text="🔀" FontSize="20" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}, Path=Foreground, Mode=OneWay}" />
                </ToggleButton>

                <!-- Favorite Toggle - Star Icon -->
                <ToggleButton Name="FavoriteButton" 
                              Width="40"
                              Height="40"
                              ToolTip="Toggle favorite"
                              IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                              Command="{Binding ToggleFavoriteCommand}">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource IconToggleButtonStyle}">
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="Gold" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                    <TextBlock Text="★" FontSize="28" Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ToggleButton}}, Path=Foreground, Mode=OneWay}" />
                </ToggleButton>
                </StackPanel>
            </DockPanel>

            <!-- THUMBNAIL VIEW -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <ScrollViewer Grid.Row="0" Background="{StaticResource BackgroundBrush}">
                    <ItemsControl Name="ThumbnailPanel" 
                                  ItemsSource="{Binding Images}"
                                  Background="{StaticResource BackgroundBrush}"
                                  Padding="10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MouseLeftButtonDown="Thumbnail_MouseLeftButtonDown"
                                      ToolTip="{Binding FileName}">
                                    <Border BorderThickness="2" 
                                            BorderBrush="{Binding IsActive, Converter={StaticResource BoolToRedBrushConverter}}"
                                            Margin="5">
                                        <Grid>
                                            <Image Source="{Binding ThumbnailData, Converter={StaticResource ByteArrayToBitmapImageConverter}}" 
                                                   Width="{Binding DataContext.ThumbnailSizePixels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Height="{Binding DataContext.ThumbnailHeightPixels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Stretch="Uniform" />
                                            <CheckBox IsChecked="{Binding IsMarked, Mode=TwoWay}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top"
                                                      Margin="5"
                                                      Background="White" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- MESSAGE LINE -->
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource ForegroundBrush}"
                       Background="{StaticResource PanelBrush}"
                       Padding="10,3"
                       FontSize="11"
                       MinHeight="25"
                       VerticalAlignment="Center" />

            <!-- STATUS BAR -->
            <Border Grid.Row="3"
                    Background="{StaticResource PanelBrush}"
                    Padding="10,5"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}">
                <TextBlock Text="{Binding Images.Count, StringFormat='Showing {0} thumbnail(s)'}"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Window>
